# ============================================================================
# Configuración de entorno para el laboratorio BD2 - Fragmentación Distribuida
# ============================================================================
# Copia este archivo como .env y ajusta los valores si es necesario.
# Los valores actuales son los defaults usados en docker-compose.yml.

# PostgreSQL Master (coordinador)
PG_MASTER_USER=abel
PG_MASTER_PASSWORD=incentivos
PG_MASTER_DB=minsa_db
PG_MASTER_PORT=5432

# PostgreSQL Worker 1
PG_WORKER1_USER=abel
PG_WORKER1_PASSWORD=incentivos
PG_WORKER1_DB=minsa_worker1
PG_WORKER1_PORT=5433

# PostgreSQL Worker 2
PG_WORKER2_USER=abel
PG_WORKER2_PASSWORD=incentivos
PG_WORKER2_DB=minsa_worker2
PG_WORKER2_PORT=5434

# Red Docker
DOCKER_NETWORK=minsa_network
